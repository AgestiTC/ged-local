# ============================================================
# DocFlow AI — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# IMPORTANT : Ne jamais committer .env dans git !
# ============================================================

# --- Base de données PostgreSQL ---
DB_PASSWORD=changeme_strong_password
DB_USER=docflow
DB_NAME=docflow
DB_HOST=postgres
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://docflow:changeme_strong_password@postgres:5432/docflow

# --- Services externes (sur l'hôte) ---
# Tika tourne sur l'hôte ou dans Docker
TIKA_URL=http://host.docker.internal:9998

# Ollama tourne sur l'hôte (GPU, pas dans Docker)
OLLAMA_URL=http://host.docker.internal:11434

# n8n tourne sur l'hôte
N8N_URL=http://host.docker.internal:5678

# --- Modèles Ollama ---
OLLAMA_MODEL_DEFAULT=mixtral:latest
OLLAMA_MODEL_FAST=mistral:latest
OLLAMA_MODEL_EMBEDDING=qwen3-embedding:8b
OLLAMA_MODEL_EMBEDDING_FALLBACK=nomic-embed-text:latest
OLLAMA_MODEL_OCR=glm-ocr:latest

# --- Dossiers surveillés (chemin HÔTE) ---
# Chemin absolu sur la machine hôte des documents à surveiller
DOCUMENTS_ROOT=C:/Users/User/Documents/DocFlow/documents

# --- Chemins de stockage (montés depuis l'hôte) ---
# Ces chemins sont relatifs à la racine du projet (docker-compose)
STORAGE_UPLOADS=./storage/uploads
STORAGE_EXPORTS=./storage/exports
STORAGE_TEMPLATES=./storage/templates

# --- Logging ---
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json         # json | console (console = plus lisible en dev)
LOG_FILE=./logs/docflow.log

# --- Backend ---
BACKEND_PORT=8000
BACKEND_WORKERS=2
DEBUG=false             # true en développement

# --- Frontend ---
FRONTEND_PORT=3001
VITE_API_URL=http://localhost:8000

# --- Chunking / Embeddings ---
CHUNK_SIZE=500          # tokens par chunk
CHUNK_OVERLAP=50        # overlap entre chunks
EMBEDDING_DIMENSION=4096 # dimension des vecteurs qwen3-embedding:8b (à vérifier au 1er test)

# --- Timeout Ollama (ms) ---
# Mixtral peut être lent sur de gros documents
OLLAMA_TIMEOUT_MS=300000    # 5 minutes

# --- Tika ---
TIKA_TIMEOUT_MS=60000       # 1 minute
