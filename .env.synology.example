# ============================================================
# DocFlow AI — Variables d'environnement Synology NAS
# ============================================================
# 1. Copier ce fichier : cp .env.synology.example .env.synology
# 2. Remplir TOUTES les valeurs marquées ← À REMPLIR
# 3. Ne jamais committer .env.synology dans git !
#
# Commande de démarrage :
#   docker compose \
#     -f docker-compose.yml \
#     -f docker-compose.synology.yml \
#     --env-file .env.synology \
#     up -d --build
# ============================================================

# ── Base de données PostgreSQL ───────────────────────────────
DB_PASSWORD=changeme_strong_password     # ← À CHANGER (mot de passe fort)
DB_USER=docflow
DB_NAME=docflow

# ── IP du PC Windows (où tournent Ollama et n8n) ────────────
# Trouver l'IP : sur le PC Windows → cmd → ipconfig
# Prendre l'adresse IPv4 de la carte réseau LAN (ex: 192.168.1.42)
WINDOWS_PC_IP=192.168.1.XXX             # ← À REMPLIR

OLLAMA_URL=http://${WINDOWS_PC_IP}:11434
N8N_URL=http://${WINDOWS_PC_IP}:5678

# ── Ports exposés sur le NAS ─────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3001
# Accès depuis le réseau local : http://IP-DU-NAS:3001

# ── Chemins sur le NAS (volumes Synology) ───────────────────
# Adapter selon votre organisation de dossiers partagés Synology

# Données PostgreSQL
SYNOLOGY_DATA_PATH=/volume1/docker/docflow/data/postgres

# Fichiers uploadés via l'interface
SYNOLOGY_UPLOADS_PATH=/volume1/docker/docflow/storage/uploads

# Rapports générés / exports
SYNOLOGY_EXPORTS_PATH=/volume1/docker/docflow/storage/exports

# Templates DOCX/PDF
SYNOLOGY_TEMPLATES_PATH=/volume1/docker/docflow/storage/templates

# Logs
SYNOLOGY_LOGS_PATH=/volume1/docker/docflow/logs

# Dossiers de documents à surveiller (lecture seule)
# Chemin sur le NAS vers vos documents existants
DOCUMENTS_ROOT=/volume1/documents       # ← À ADAPTER

# ── Modèles Ollama ───────────────────────────────────────────
OLLAMA_MODEL_DEFAULT=mixtral:latest
OLLAMA_MODEL_FAST=mistral:latest
OLLAMA_MODEL_EMBEDDING=qwen3-embedding:8b
OLLAMA_MODEL_EMBEDDING_FALLBACK=nomic-embed-text:latest

# ── Chunking / Embeddings ────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBEDDING_DIMENSION=4096               # Vérifier au 1er démarrage avec qwen3-embedding:8b

# ── Timeouts ─────────────────────────────────────────────────
OLLAMA_TIMEOUT_MS=300000               # 5 minutes (Mixtral est lent)
TIKA_TIMEOUT_MS=60000                  # 1 minute

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
DEBUG=false
