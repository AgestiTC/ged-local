# ============================================================
# DocFlow AI — Variables NAS (images depuis registry Gitea)
# ============================================================
# Copier : cp .env.nas.example .env
# Docker Compose charge .env automatiquement — aucun flag --env-file nécessaire
# Remplir les 3 variables obligatoires marquées ← OBLIGATOIRE
# ============================================================

# ── Version des images ───────────────────────────────────────
# latest = dernière image buildée depuis main
# v1.4.0 = version épinglée (recommandé en production)
DOCFLOW_VERSION=latest

# ── Base de données ──────────────────────────────────────────
DB_PASSWORD=changeme_mot_de_passe_fort   # ← OBLIGATOIRE
DB_USER=docflow
DB_NAME=docflow

# ── Ollama (PC Windows) ──────────────────────────────────────
# ipconfig sur le PC → adresse IPv4 LAN
OLLAMA_URL=http://192.168.1.XXX:11434    # ← OBLIGATOIRE

# ── Documents à surveiller ───────────────────────────────────
DOCUMENTS_ROOT=/volume1/documents        # ← ADAPTER si besoin

# ── Chemins de stockage sur le NAS ───────────────────────────
DATA_PATH=/volume1/docker/docflow/data/postgres
UPLOADS_PATH=/volume1/docker/docflow/storage/uploads
EXPORTS_PATH=/volume1/docker/docflow/storage/exports
TEMPLATES_PATH=/volume1/docker/docflow/storage/templates
LOGS_PATH=/volume1/docker/docflow/logs

# ── Ports exposés ────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3001

# ── Modèles Ollama (optionnel — valeurs par défaut ok) ───────
# OLLAMA_MODEL_DEFAULT=mixtral:latest
# OLLAMA_MODEL_FAST=mistral:latest
# OLLAMA_MODEL_EMBEDDING=qwen3-embedding:8b
# EMBEDDING_DIMENSION=4096
# OLLAMA_TIMEOUT_MS=300000
